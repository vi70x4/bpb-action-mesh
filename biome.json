{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/",
			"!**/node_modules/",
			"!**/worker/.wrangler/",
			"!**/node/dist/",
			"!**/*.min.js"
		]
	}
}
