{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"root": false,
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noUnusedFunctionParameters": "warn",
				"noUnusedVariables": "error"
			}
		}
	},
	"files": {
		"includes": ["src/**", "!**/dist/"]
	}
}
